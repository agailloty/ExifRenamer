<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:ExifRenamer.ViewModels"
        xmlns:views="using:ExifRenamer.Views"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="600"
        x:Class="ExifRenamer.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/ExifRenamer.ico"
        WindowStartupLocation="CenterScreen"
        Title="Exif Renamer">

    <Design.DataContext>
        <vm:MainWindowViewModel />
    </Design.DataContext>

    <Window.Styles>
        <Style Selector="ListBoxItem">
            <Setter Property="DataContext" Value="{Binding}" />
        </Style>
        <Style Selector="TabItem">
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Padding" Value="12 6" />
        </Style>
    </Window.Styles>

    <!-- Root Panel allows the overlay to sit above everything -->
    <Panel>

        <DockPanel Margin="5" LastChildFill="True">

            <!-- ── Main TabControl ────────────────────────────────────────── -->
            <TabControl>

                <!-- Tab 1 : Photo Renamer -->
                <TabItem Header="📷  Rename photos">
                    <Grid Margin="5" ColumnDefinitions="*,2*" RowDefinitions="*,5*,*,Auto">

                        <StackPanel Grid.Column="0" Grid.Row="1" Margin="0 0 30 0" Grid.RowSpan="2">
                            <Label Margin="0 0 0 10" FontWeight="ExtraBold" Content="Add folders" FontSize="20" />
                            <TextBlock TextWrapping="Wrap" Margin="0 0 0 10"
                                       Text="Add the folders that contains your photos" />
                            <ScrollViewer MaxHeight="350" HorizontalScrollBarVisibility="Disabled">
                                <ListBox ItemsSource="{Binding PathFolders}">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Margin="1">
                                                <Grid ColumnDefinitions="*, Auto">
                                                    <TextBlock Grid.Column="0"
                                                               ToolTip.Tip="{Binding FullName}"
                                                               Text="{Binding Name}"
                                                               TextWrapping="WrapWithOverflow" />
                                                    <Button Grid.Column="1"
                                                            Command="{Binding $parent[views:MainWindow].ViewModel.RemoveFolderCommand}"
                                                            CommandParameter="{Binding}"
                                                            VerticalAlignment="Top" HorizontalAlignment="Right">
                                                        <Button.ContentTemplate>
                                                            <DataTemplate>
                                                                <Image Margin="0" Width="15" Height="15"
                                                                       VerticalAlignment="Top"
                                                                       HorizontalAlignment="Right"
                                                                       Source="/Assets/deletebtn.png" />
                                                            </DataTemplate>
                                                        </Button.ContentTemplate>
                                                    </Button>
                                                </Grid>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </ScrollViewer>
                        </StackPanel>

                        <Button Grid.Column="0" Grid.Row="3"
                                Content="ADD FOLDER" FontSize="16"
                                Command="{Binding AddFolderCommand}" />
                        <Button Grid.Column="1" Grid.Row="3"
                                IsVisible="{Binding HasImages}"
                                HorizontalAlignment="Right"
                                IsEnabled="{Binding IsRenameEnabled}"
                                FontSize="16" Content="RENAME"
                                Command="{Binding RenameCommand}" />
                        <StackPanel Grid.Column="1" Grid.Row="3"
                                    IsVisible="{Binding HasImages}"
                                    VerticalAlignment="Bottom"
                                    HorizontalAlignment="Center"
                                    Orientation="Horizontal">
                            <TextBlock Text="Image count : " />
                            <TextBlock Text="{Binding TotalImagesCount}" />
                        </StackPanel>

                        <Grid Grid.Column="1" Grid.Row="0" RowSpan="3"
                              IsVisible="{Binding HasImages}"
                              ColumnDefinitions="1*,2*"
                              RowDefinitions="Auto,Auto,3*">
                            <ComboBox IsVisible="{Binding !IsCustomSelected}"
                                      Grid.Column="0" Grid.Row="0"
                                      Margin="0 2 0 2"
                                      ItemsSource="{Binding RenamerDateTypes}"
                                      SelectedItem="{Binding SelectedRenamerDateType, Mode=TwoWay}">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Name}" />
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>

                            <StackPanel Grid.Column="0" Grid.Row="1">
                                <ComboBox VerticalAlignment="Top" HorizontalAlignment="Stretch"
                                          ItemsSource="{Binding BuiltInRenamerPatterns}"
                                          SelectedItem="{Binding SelectedDateRenamerPattern, Mode=TwoWay}">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock ToolTip.Tip="{Binding Description}"
                                                       Text="{Binding Name}" />
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>

                                <Button Content="Exif Explorer" VerticalAlignment="Bottom" Margin="0 5 0 0"
                                        Command="{Binding ShowExifExplorerCommand}"
                                        IsVisible="{Binding IsCustomSelected}" />
                            </StackPanel>

                            <StackPanel Grid.Column="1" Grid.Row="1" Orientation="Horizontal">
                                <TextBox Margin="5 0 5 0" VerticalAlignment="Top"
                                         IsVisible="{Binding IsSelectExifVisible}"
                                         Text="{Binding CustomFormat}"
                                         MinWidth="250" MaxWidth="350" />
                                <Button Content="OK" HorizontalAlignment="Right"
                                        VerticalAlignment="Top"
                                        Command="{Binding ValidateCustomFormatCommand}"
                                        IsVisible="{Binding IsSelectExifVisible}" />
                            </StackPanel>

                            <StackPanel IsVisible="{Binding IsCustomDateFormat}"
                                        Grid.Column="1" Grid.Row="1" Orientation="Horizontal">
                                <TextBox Margin="5 0 5 0" VerticalAlignment="Top"
                                         Text="{Binding CustomDateFormat}"
                                         MinWidth="250" MaxWidth="350" />
                                <Button Content="OK" HorizontalAlignment="Right"
                                        VerticalAlignment="Top"
                                        Command="{Binding ValidateCustomFormatCommand}" />
                            </StackPanel>

                            <views:RenamePreviewer Grid.Column="0" Grid.Row="2"
                                                   Margin="0 40 0 0"
                                                   Grid.ColumnSpan="2" />
                        </Grid>
                    </Grid>
                </TabItem>

                <!-- Tab 2 : Video Compressor (visible only when feature is enabled + ffmpeg is configured) -->
                <TabItem Header="🎬  Compress videos"
                         IsVisible="{Binding Settings.IsVideoTabVisible}">
                    <views:VideoCompressorView DataContext="{Binding VideoCompressor}" />
                </TabItem>

                <!-- Tab 3 : Settings -->
                <TabItem Header="⚙  Settings">
                    <ScrollViewer Padding="10">
                        <StackPanel Spacing="20" MaxWidth="600">

                            <!-- ── Video Compression ──────────────────────── -->
                            <StackPanel Spacing="10">
                                <TextBlock Text="Video Compression"
                                           FontWeight="ExtraBold" FontSize="16" />
                                <TextBlock TextWrapping="Wrap" Opacity="0.7"
                                           Text="This feature uses ffmpeg to reduce video file sizes. It is disabled by default. A valid ffmpeg installation is required to enable it." />

                                <!-- ffmpeg path -->
                                <Grid ColumnDefinitions="Auto,*,Auto,Auto" Margin="0 4 0 0">
                                    <TextBlock Grid.Column="0"
                                               Text="ffmpeg path:"
                                               FontWeight="SemiBold"
                                               VerticalAlignment="Center"
                                               Margin="0 0 10 0" />
                                    <TextBox Grid.Column="1"
                                             Text="{Binding Settings.FfmpegPath, Mode=TwoWay}"
                                             PlaceholderText="Path to ffmpeg.exe…"
                                             VerticalAlignment="Center" />
                                    <TextBlock Grid.Column="2"
                                               Margin="8 0 0 0"
                                               VerticalAlignment="Center"
                                               FontSize="18"
                                               IsVisible="{Binding Settings.IsFfmpegConfigured}"
                                               Text="✓" Foreground="Green"
                                               ToolTip.Tip="ffmpeg found and valid" />
                                    <TextBlock Grid.Column="2"
                                               Margin="8 0 0 0"
                                               VerticalAlignment="Center"
                                               FontSize="18"
                                               IsVisible="{Binding !Settings.IsFfmpegConfigured}"
                                               Text="✗" Foreground="OrangeRed"
                                               ToolTip.Tip="Path not set or executable not found" />
                                    <Button Grid.Column="3"
                                            Margin="6 0 0 0"
                                            Content="Browse…"
                                            Command="{Binding Settings.BrowseFfmpegCommand}" />
                                </Grid>

                                <!-- Enable toggle -->
                                <ToggleSwitch IsChecked="{Binding Settings.IsVideoCompressionEnabled, Mode=TwoWay}"
                                             IsEnabled="{Binding Settings.IsFfmpegConfigured}"
                                             OnContent="Enabled"
                                             OffContent="Disabled"
                                             Margin="0 4 0 0" />
                                <TextBlock IsVisible="{Binding !Settings.IsFfmpegConfigured}"
                                           Opacity="0.6" FontStyle="Italic" TextWrapping="Wrap"
                                           Text="⚠ Set a valid ffmpeg path above to enable this feature." />
                            </StackPanel>

                            <!-- ── Output ─────────────────────────────────── -->
                            <StackPanel Spacing="8"
                                        IsVisible="{Binding Settings.IsVideoCompressionEnabled}">
                                <TextBlock Text="Output"
                                           FontWeight="ExtraBold" FontSize="16" />
                                <Grid ColumnDefinitions="Auto,*">
                                    <TextBlock Grid.Column="0"
                                               Text="Output subfolder name:"
                                               FontWeight="SemiBold"
                                               VerticalAlignment="Center"
                                               Margin="0 0 10 0" />
                                    <TextBox Grid.Column="1"
                                             Text="{Binding Settings.OutputSubfolderName, Mode=TwoWay}"
                                             PlaceholderText="e.g. Final" />
                                </Grid>
                                <TextBlock Opacity="0.6" FontStyle="Italic" TextWrapping="Wrap"
                                           Text="Compressed videos are saved in a subfolder with this name inside the source folder." />
                            </StackPanel>

                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

            </TabControl>
        </DockPanel>

        <!-- Overlay (must be last child so it renders above everything) -->
        <Grid IsVisible="False" x:Name="MainWindowOverlay"
              Background="Black" Opacity="0.3" ZIndex="1000" />

    </Panel>
</Window>