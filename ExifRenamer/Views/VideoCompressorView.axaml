<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:ExifRenamer.ViewModels"
             xmlns:models="using:ExifRenamer.Models"
             mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="600"
             x:DataType="vm:VideoCompressorViewModel"
             x:Class="ExifRenamer.Views.VideoCompressorView">

    <Grid Margin="5" RowDefinitions="Auto,Auto,*,Auto">

        <!-- ── Row 0 : Folders + Options ───────────────────────────────── -->
        <Grid Grid.Row="0" ColumnDefinitions="1*,2*" Margin="0 0 0 10">

            <!-- Left column : source folders -->
            <StackPanel Grid.Column="0" Margin="0 0 20 0">
                <Label FontWeight="ExtraBold" FontSize="16" Margin="0 0 0 8"
                       Content="Dossiers sources" />
                <TextBlock TextWrapping="Wrap" Margin="0 0 0 8" Opacity="0.7"
                           Text="Vidéos traitées : .mp4 .mov .avi .mkv .wmv .flv .m4v .webm" />
                <ScrollViewer MaxHeight="220" HorizontalScrollBarVisibility="Disabled">
                    <ListBox ItemsSource="{Binding Folders}">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid ColumnDefinitions="*,Auto">
                                    <TextBlock Grid.Column="0" Text="{Binding Name}"
                                               ToolTip.Tip="{Binding FullName}"
                                               TextWrapping="WrapWithOverflow" />
                                    <Button Grid.Column="1"
                                            Command="{Binding $parent[UserControl].((vm:VideoCompressorViewModel)DataContext).RemoveFolderCommand}"
                                            CommandParameter="{Binding}"
                                            VerticalAlignment="Top" HorizontalAlignment="Right">
                                        <Button.ContentTemplate>
                                            <DataTemplate>
                                                <Image Width="12" Height="12"
                                                       Source="/Assets/deletebtn.png" />
                                            </DataTemplate>
                                        </Button.ContentTemplate>
                                    </Button>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </ScrollViewer>
                <Button Content="AJOUTER UN DOSSIER" Margin="0 10 0 0"
                        Command="{Binding AddFolderCommand}" />
            </StackPanel>

            <!-- Right column : compression options -->
            <StackPanel Grid.Column="1" Spacing="8">
                <Label FontWeight="ExtraBold" FontSize="16" Content="Options de compression" />

                <!-- Preset selector -->
                <TextBlock Text="Préréglage :" FontWeight="SemiBold" />
                <ComboBox HorizontalAlignment="Stretch"
                          ItemsSource="{Binding Presets}"
                          SelectedItem="{Binding SelectedPreset, Mode=TwoWay}">
                    <ComboBox.ItemTemplate>
                        <DataTemplate x:DataType="models:VideoCompressionPreset">
                            <StackPanel Margin="2">
                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold" />
                                <TextBlock Text="{Binding Description}" FontSize="11" Opacity="0.65" />
                            </StackPanel>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>

                <!-- Postfix option -->
                <CheckBox Content="Ajouter un suffixe au nom du fichier de sortie"
                          IsChecked="{Binding UsePostfix, Mode=TwoWay}"
                          Margin="0 4 0 0" />
                <StackPanel IsVisible="{Binding UsePostfix}"
                            Orientation="Horizontal" Spacing="8" Margin="16 0 0 0">
                    <TextBlock Text="Suffixe :" VerticalAlignment="Center" />
                    <TextBox Text="{Binding Postfix, Mode=TwoWay}"
                             MinWidth="70" MaxWidth="120" />
                    <TextBlock VerticalAlignment="Center" Opacity="0.6"
                               Text="(ex : videoV.mp4)" />
                </StackPanel>
            </StackPanel>
        </Grid>

        <!-- ── Row 1 : Action bar ──────────────────────────────────────── -->
        <Grid Grid.Row="1" ColumnDefinitions="Auto,Auto,*,Auto"
              Margin="0 0 0 8">
            <Button Grid.Column="0" Content="▶  COMPRESSER"
                    FontSize="14" FontWeight="SemiBold"
                    IsEnabled="{Binding CanStart}"
                    Command="{Binding StartCommand}" />
            <Button Grid.Column="1" Content="⬛  ANNULER"
                    FontSize="14" Margin="10 0 0 0"
                    IsEnabled="{Binding IsRunning}"
                    Command="{Binding CancelCommand}" />
            <StackPanel Grid.Column="3" Orientation="Horizontal"
                        VerticalAlignment="Center" Spacing="4"
                        IsVisible="{Binding IsRunning}">
                <TextBlock Text="{Binding ProcessedCount}" />
                <TextBlock Text="/" />
                <TextBlock Text="{Binding TotalCount}" />
                <TextBlock Text="fichiers" />
            </StackPanel>
        </Grid>

        <!-- ── Row 2 : Jobs list ───────────────────────────────────────── -->
        <Border Grid.Row="2" BorderThickness="1" CornerRadius="4">
            <ScrollViewer HorizontalScrollBarVisibility="Disabled">
                <ListBox Background="Transparent"
                         ItemsSource="{Binding Jobs}">
                    <ListBox.ItemTemplate>
                        <DataTemplate x:DataType="vm:VideoCompressionJobViewModel">
                            <Grid ColumnDefinitions="3*,Auto,3*,2*" Margin="2 3">
                                <TextBlock Grid.Column="0"
                                           Text="{Binding InputFilename}"
                                           TextTrimming="CharacterEllipsis"
                                           ToolTip.Tip="{Binding InputPath}" />
                                <TextBlock Grid.Column="1" Text=" → "
                                           HorizontalAlignment="Center"
                                           Opacity="0.5" />
                                <TextBlock Grid.Column="2"
                                           Text="{Binding OutputFilename}"
                                           TextTrimming="CharacterEllipsis"
                                           ToolTip.Tip="{Binding OutputPath}" />
                                <TextBlock Grid.Column="3"
                                           Text="{Binding StatusText}"
                                           TextTrimming="CharacterEllipsis"
                                           ToolTip.Tip="{Binding ErrorMessage}"
                                           HorizontalAlignment="Right" />
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </ScrollViewer>
        </Border>

        <!-- ── Row 3 : Status bar ──────────────────────────────────────── -->
        <TextBlock Grid.Row="3" Margin="0 6 0 0"
                   Text="{Binding StatusMessage}"
                   TextTrimming="CharacterEllipsis"
                   Opacity="0.75" />
    </Grid>
</UserControl>
